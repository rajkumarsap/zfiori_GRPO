<c:FragmentDefinition
	xmlns="sap.m"
	xmlns:c="sap.ui.core"
>
	<Dialog
		id="printLabelDialog"
		titleAlignment="Center"
		contentWidth="60%"
		title="{i18n>PrintLabelsHeader}"
	>
		<Table
			id="idPrintLabelsTable"
			items="{oJsonPrintLabelModel>/results}"
			class="sapUiTinyMarginTop printLabelTable"
			growing="true"
			growingScrollToLoad="true"
		>
			<headerToolbar>
				<OverflowToolbar id="OverflowToolbar1">
					<content>
						<ToolbarSpacer id="toolbar"/>
						<SearchField
							id="searchFieldId_printLabel"
							placeholder="Search"
							liveChange="onSearchLabelPrintTable"
							width="40%"
						/>
					</content>
				</OverflowToolbar>
			</headerToolbar>
			<columns>
				<Column
					width="3rem"
					id="MaterialNumberColumn"
				>
					<Text
						id="MaterialNumberId"
						text="{i18n>MaterialNumber}"
					/>
				</Column>
				<Column
					width="6rem"
					popinDisplay="Inline"
					id="MaterialDescColumn"
				>
					<Text
						id="MaterialDescId"
						text="{i18n>MaterialDesc}"
					/>
				</Column>
				<Column
					width="4rem"
					popinDisplay="Inline"
					id="BinColumn"
				>
					<Text
						id="binId"
						text="{i18n>bin}"
					/>
				</Column>
				<Column
					width="4rem"
					popinDisplay="Inline"
					id="CopiesColumn"
					demandPopin="true"
					minScreenWidth="Large"
				>
					<Text
						id="CopiesId"
						text="{i18n>Copies}"
					/>
				</Column>
			</columns>
			<items>
				<ColumnListItem id="Copies">
					<cells>
						<Text
							id="printLabelMaterialNo"
							text="{oJsonPrintLabelModel>Materialno}"
						/>
						<Text
							id="printLabelMaterialDesc"
							text="{oJsonPrintLabelModel>Description}"
						/>
						<Text
							id="printLabelBinLocation"
							text="{oJsonPrintLabelModel>Storagebin}"
						/>
						<StepInput
							id="pintLabelTotalCopies"
							value="{oJsonPrintLabelModel>TotalCopies}"
							max="100"
							min="0"
							width="3rem"
							change="onStepInputValueChange"
						/>
					</cells>
				</ColumnListItem>
			</items>
		</Table>
		<beginButton>
			<Button
				id="printBtn"
				text="{i18n>Print}"
				press="onPressPrintMaterial"
				enabled="false"
				type="Accept"
			/>
		</beginButton>
		<endButton>
			<Button
				id="printLabelCancelBtn"
				text="{i18n>Cancel}"
				press="onPressPrintLabelCancel"
				type="Reject"
			/>
		</endButton>
	</Dialog>
</c:FragmentDefinition>