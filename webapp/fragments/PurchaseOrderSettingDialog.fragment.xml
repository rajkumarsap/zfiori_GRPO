<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
        <Dialog
            id="mTypeSelectDialog"
            title="{i18n>poSettingType}">
                <VBox
                    id="_IDGenVBox1"
                    class="sapUiSmallMargin">
                        <HBox
                            id="id_purchaseGroup_Hbox"
                            alignItems="Center"
                            class="sapUiSizeCompact">
                                <Label
                                    id="id_purchaseGroup_Label"
                                    text="{i18n>SPurchaseGroup}"
                                    design="Bold"
                                    textAlign="Begin"
                                    textDirection="Inherit"
                                    class="sapUiSmallMarginEnd"
                                    width="7.7rem"/>
                                <MultiComboBox 
                                    id="id_purchaseGroupMultiCombobox_Field"
                                    selectionChange="handlePurGroupChange"
                                    width="350px"
                                    class="input_css"
                                    items="{
                                        path: 'oPurchasingGroupJsonSet>/results',
                                        sorter: { path: 'PurGroup' },
                                        length: 1000
                                    }">
                                    <core:Item
                                        id="id_item_combobox_purchaseGroup" 
                                        key="{oPurchasingGroupJsonSet>PurGroup}" 
                                        text="{oPurchasingGroupJsonSet>PurGroup} {oPurchasingGroupJsonSet>PurGroupDesc}"/>
                                </MultiComboBox>
                        </HBox>
                        <HBox
                            id="id_dateRange_HBox"
                            alignItems="Center"
                            class="sapUiSizeCompact">
                                <Label
                                    id="id_DateRange_Label"
                                    text="{i18n>SDateRange}"
                                    textAlign="Begin"
                                    design="Bold"
                                    textDirection="Inherit"
                                    class="sapUiSmallMarginEnd"
                                    width="7.7rem"/>
                                <DateRangeSelection
                                    id="id_dts_range"
                                    width="350px"
                                    displayFormat="short"
                                    class="dateInputHide input_css"
                                    change="handleChange"/>
                        </HBox>
                        <HBox
                            id="id_receipt_status_Hbox"
                            alignItems="Center"
                            class="sapUiSizeCompact">
                                <Label
                                    id="id_ReceiptStatus_Label"
                                    text="{i18n>receiptStatus}"
                                    textAlign="Begin"
                                    design="Bold"
                                    textDirection="Inherit"
                                    class="sapUiSmallMarginEnd"
                                    width="7.7rem"/>
                                <VBox id="id_ReceiptStatusCombobox_Vbox" width="100%">
                                    <ComboBox
                                        items="{getReceiptStatusModelName>/results}"
                                        id="idReceiptStatus_combobox"
                                        class="input_css"
                                        width="350px"
                                        placeholder="{i18n>selectReceiptStatus}">
                                            <core:ListItem
                                                id="_IDGenListItem1"
                                                key="{getReceiptStatusModelName>StatusCode}"
                                                text="{getReceiptStatusModelName>Description}"/>
                                    </ComboBox>
                                </VBox>
                        </HBox>
		        </VBox>
                <buttons>
                    <Button
                        id="updateButtonID"
                        type="Emphasized"
                        text="{i18n>okButtonText}"
                        press="onPurchaseGroupFilterOkPress"/>
                    <Button
                        id="createButtonID"
                        text="{i18n>cancel}"
                        press="onPurchaseGroupCancelPress"/>
                    <Button
                        id="idreset"
                        text="{i18n>Reset}"
                        press="onPurchaseGroupResetPress"/>
                </buttons>
	    </Dialog>
</core:FragmentDefinition>