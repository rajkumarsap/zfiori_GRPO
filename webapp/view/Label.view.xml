<mvc:View
    controllerName="com.wel.goodsreceipt.controller.Label"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:semantic="sap.f.semantic"
	xmlns:l="sap.ui.layout">
        <semantic:SemanticPage
            id="LablePage"
            preserveHeaderStateOnScroll="true"
            showFooter="true">
                <semantic:titleHeading>
                    <Title
                        id="id_label_title"
                        text="{i18n>Label}"
                        wrapping="true"/>
                </semantic:titleHeading>
                <semantic:content>
                    <Table
                        id="id_Label_table"
                        inset="false"
                        items="{ path: 'labelJsonModel>/results' }"
                        mode="None">
                        <headerToolbar>
                            <OverflowToolbar id="id_overflow_in_label">
                                    <content>
                                        <VBox id="id_headertoolbar_in_label">
                                            <Title
                                                id="id_header_overFlowToolbar_label_table_ShortText"
                                                level="H5"
                                                text="Description"/>
                                        </VBox>
                                        <ToolbarSpacer id="id_toolbar_spacer_label"/>
                                    </content>
                                </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <Column
                                id="id_label_column_LabelPrefix"
                                width="7rem"
                                hAlign="Center"
                                popinDisplay="Inline">
                                <Text
                                    id="id_label_textfield_LabelPrefix"
                                    text="{i18n>LabelPrefix}"/>
                            </Column>
                            <Column
                                id="id_label_column_CounterStart"
                                width="7rem"
                                demandPopin="false"
                                minScreenWidth=""
                                hAlign="Center"
                                popinDisplay="Inline">
                                <Text
                                    id="id_label_textfield_counterStart"
                                    text="{i18n>CounterStart}"/>
                            </Column>
                            <Column
                                id="id_label_column_LabelSuffix"
                                width="7rem"
                                hAlign="Center"
                                popinDisplay="Inline">
                                <Text
                                    id="id_label_textfield_LabelSuffix"
                                    text="{i18n>LabelSuffix}"/>
                            </Column>
                            <Column
                                id="id_label_column_LabelStart"
                                minScreenWidth="Tablet"
                                demandPopin="true"
                                width="8rem"
                                hAlign="Center"
                                popinDisplay="Inline">
                                <Text
                                    id="id_label_textfield_LabelStart"
                                    text="{i18n>LabelStart}"/>
                            </Column>
                            <Column
                                id="id_label_column_LabelEmd"
                                minScreenWidth="Tablet"
                                demandPopin="true"
                                width="8rem"
                                hAlign="Center"
                                popinDisplay="Inline">
                                <Text
                                    id="id_label_textfield_LabelEnd"
                                    text="{i18n>LabelEnd}"/>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem id="_IDGenColumnListItem1">
                                <cells>
                                    <Input
                                        id="id_label_input_field_LabelPrefix"
                                        value="{labelJsonModel>LabelPrefix}"
                                        liveChange="onLabelPrefixAndValueChange"
                                        width="6rem"
                                        class="input_css"/>
                                    <Input
                                        id="id_label_input_field_counterStart"
                                        liveChange="onCounterValueChange"
                                        value="{labelJsonModel>StartCounter}"
                                        width="6rem"
                                        type="Number"
                                        class="input_css"/>
                                    <Input
                                        id="id_label_input_field_LabelSuffix"
                                        value="{labelJsonModel>LabelSuffix}"
                                        liveChange="onLabelSuffixAndValueChange"
                                        width="6rem"
                                        class="input_css"/>
                                    <Text
                                        id="id_cell_label_Start"
                                        text="{path:'labelJsonModel>LabelStart'}"/>
                                    <Text
                                        id="id_cell_label_End"
                                        text="{path:'labelJsonModel>LabelEnd'}"/>
                                    <!-- {path:'labelJsonModel>LabelPrefix'}
                                    {path:'labelJsonModel>LabelPrefix'} -->
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </semantic:content>
                    <!--Semantic ShareMenu Buttons-->
                    <semantic:closeAction>
                        <semantic:CloseAction
                            id="closeColumn"
                            press="onCloseDetailPress"/>
                    </semantic:closeAction>
                    <semantic:positiveAction>
                        <semantic:PositiveAction
                            id="id_saveLabel_labelPage"
                            visible="true"
                            text="{i18n>Save}"
                            press="onSaveLabelButtonPress"/>
                    </semantic:positiveAction>
                    <semantic:negativeAction>
                        <semantic:NegativeAction
                            id="id_reset"
                            visible="true"
                            text="{i18n>Cancel}"
                            press="onCloseDetailPress"/>
                    </semantic:negativeAction>
                </semantic:SemanticPage>
</mvc:View>