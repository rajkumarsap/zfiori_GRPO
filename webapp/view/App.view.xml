<mvc:View
    controllerName="com.wel.goodsreceipt.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f">
        <App
            id="app"
            busy="{appView>/busy}"
            busyIndicatorDelay="{appView>/delay}">
            <f:FlexibleColumnLayout
                id="layout"
                layout="{appView>/layout}"
                backgroundDesign="Translucent">
            </f:FlexibleColumnLayout>
	    </App>
</mvc:View>
