<mvc:View
	controllerName="com.wel.goodsreceipt.controller.Detail"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:semantic="sap.f.semantic"
	xmlns:l="sap.ui.layout"
>
	<semantic:SemanticPage
		id="detailPage"
		busy="{detailView>/busy}"
		busyIndicatorDelay="{detailView>/delay}"
		showFooter="true"
	>
		<semantic:titleHeading>
		
			<Title
				id="idVendorName"
				text="THIS is my test"
				wrapping="true"
			/>
		</semantic:titleHeading>
		<semantic:headerContent>
			<VBox
				id="_IDGenVBox1"
				justifyContent="Center"
				class="sapUiTinyMarginBottom"
			>
				<l:HorizontalLayout id="_IDGenHorizontalLayout1">
					<Label
						id="_IDGenLabel1"
						text="{i18n>headerLablePO}"
						width="8em"
					/>
					<Text
						id="_IDGenText1"
						class="sapUiSmallMarginEnd"
						text=":"
						width=".1em"
					/>
					<Text id="idPONumber"/>
				</l:HorizontalLayout>
			</VBox>
			<VBox
				id="_IDGenVBox2"
				justifyContent="Center"
				class="sapUiSizeCompact"
			>
				<l:HorizontalLayout id="_IDGenHorizontalLayout2">
					<Label
						id="_IDGenLabel2"
						text="{i18n>documentDate}"
						width="8em"
					/>
					<Text
						id="_IDGenText2"
						class="sapUiSmallMarginEnd"
						text=":"
						width=".1em"
					/>
					<DatePicker
						id="id_documentdate"
						displayFormat="medium"
						class="dateInputHide input_css"
					/>
				</l:HorizontalLayout>
			</VBox>
			<VBox
				id="_IDGenVBox3"
				justifyContent="Center"
				class="sapUiSizeCompact"
			>
				<l:HorizontalLayout id="_IDGenHorizontalLayout3">
					<Label
						id="_IDGenLabel3"
						text="{i18n>postingDate}"
						width="8em"
					/>
					<Text
						id="_IDGenText3"
						class="sapUiSmallMarginEnd"
						text=":"
						width=".1em"
					/>
					<DatePicker
						id="id_postingdate"
						displayFormat="medium"
						class="dateInputHide input_css"
					/>
				</l:HorizontalLayout>
			</VBox>
			<VBox
				id="_IDGenVBox4"
				justifyContent="Center"
				class="sapUiSizeCompact"
			>
				<l:HorizontalLayout id="_IDGenHorizontalLayout4">
					<Label
						id="_IDGenLabel4"
						text="{i18n>deliveryNote}"
						width="8em"
						required="true"
					/>
					<Text
						id="_IDGenText4"
						class="sapUiSmallMarginEnd"
						text=":"
						width=".1em"
					/>
					<TextArea
						id="deleveryNote"
						placeholder="Enter delivery text"
						width="12.5rem"
						liveChange="OnDeliveryNoteChange"
						class="input_css" 
						maxLength="16"
					/>
				</l:HorizontalLayout>
			</VBox>
			<VBox
				id="_IDGenVBox5"
				justifyContent="Center"
				class="sapUiTinyMarginTop sapUiTinyMarginBottom"
			>
				<l:HorizontalLayout id="_IDGenHorizontalLayout5">
					<Label
						id="_IDGenLabel5"
						text="{i18n>Status}"
						width="8em"
					/>
					<Text
						id="_IDGenText5"
						class="sapUiSmallMarginEnd"
						text=":"
						width=".1em"
					/>
					<Text id="idStatus"/>
				</l:HorizontalLayout>
			</VBox>
		</semantic:headerContent>
		<semantic:content>
			<Table
				id="id_POitemTable"
				alternateRowColors="true"
				items="{
					path: 'poItemGlobalJsonModel>/results',
					sorter: {
						path: 'Name'
					}
				}"
				growing="true"
				growingThreshold="2000"
				width="auto"
                class="sapFSemanticPageAlignContent"
			>
				<headerToolbar>
					<OverflowToolbar id="_IDGenOverflowToolbar1">
						<content>
							<Title
								id="id_TemTitle"
								text=""
								level="H2"
							/>
							<ToolbarSpacer id="_IDGenToolbarSpacer1"/>
							<SearchField
								id="searchField"
								placeholder="Search"
								search="onSearchPOItemTable"
								width="auto"
							/>
						</content>
					</OverflowToolbar>
				</headerToolbar>
				<columns>
					<Column
						id="id_detail_itemNumber"
						width="5rem"
						popinDisplay="Inline"
					>
						<Text
							id="id_text_itemNo"
							text="{i18n>itemNumber}"
						/>
					</Column>
					<Column
						id="id_detail_MaterialNumber"
						width="5rem"
						popinDisplay="Inline"
					>
						<Text
							id="id_text_Materialno"
							text="{i18n>Materialno}"
						/>
					</Column>
					<Column
						id="id_detail_shortTExt"
						demandPopin="true"
						minScreenWidth="Desktop"
						width="auto"
						popinDisplay="Inline"
					>
						<Text
							id="id_text_shortText"
							text="{i18n>shortText}"
						/>
					</Column>
					<Column
						id="id_detail_storageLocation"
						demandPopin="true"
						minScreenWidth="Desktop"
						width="6rem"
						popinDisplay="Inline"
					>
						<Text
							id="id_text_sloc"
							text="{i18n>bin}"
						/>
					</Column>
					<Column
						id="id_detail_vendormat"
						demandPopin="true"
						minScreenWidth="Desktop"
						width="6rem"
						popinDisplay="Inline"
					>
						<Text
							id="id_text_vendor"
							text="{i18n>vendormaterial}"
						/>
					</Column>
					<Column
						id="id_detail_netPrice"
						minScreenWidth="Desktop"
						demandPopin="true"
						width="6rem"
						popinDisplay="Inline"
					>
						<Text
							id="_IDGenText8"
							text="{i18n>netPrice}"
						/>
					</Column>
					<Column
						id="id_detail_orderQuantity"
						minScreenWidth="Tablet"
						demandPopin="true"
						width="5rem"
						popinDisplay="Inline"
					>
						<Text
							id="_IDGenText9"
							text="{i18n>orderQuantity}"
						/>
					</Column>
					<Column
						id="id_detail_receivQuantity"
						minScreenWidth="Tablet"
						demandPopin="true"
						width="5rem"
						popinDisplay="Inline"
					>
						<Text
							id="_IDGenText10"
							text="{i18n>receivQuantity}"
						/>
					</Column>
					<Column
						id="id_unit_column"
						minScreenWidth="Tablet"
						demandPopin="true"
						width="4rem"
						hAlign="Center"
						popinDisplay="Inline"
					>
						<Text
							id="_IDGenText11"
							text="{i18n>unit}"
						/>
					</Column>
					<Column
						id="id_posting_quantity"
						minScreenWidth="Tablet"
						demandPopin="true"
						width="6rem"
						hAlign="Center"
						popinDisplay="Inline"
					>
						<Text
							id="id_textfield_for_postingQuantity"
							text="{i18n>postingQuantity}"
						/>
					</Column>
					<Column
						id="id_batch_column"
						minScreenWidth="Tablet"
						demandPopin="true"
						width="6rem"
						hAlign="Center"
						popinDisplay="Inline"
					>
						<Text
							id="id_bat_textfield"
							text="{i18n>batch}"
						/>
					</Column>
					<Column
						id="gen_id_columns"
						width="6rem"
						hAlign="Center"
						popinDisplay="Inline"
					>
						<Text
							id="somethhing"
							text="Action"
						/>
					</Column>
				</columns>
				<items>
					<ColumnListItem
						id="id_columnListItem_of_Po_table"
						visible="{
							path: 'poItemGlobalJsonModel>SubItemno',
							formatter: '.formatter.oSubItemCheck'
						}"
					>
						<cells>
							<ObjectIdentifier
								id="id_gen_Itemno"
								title="{
									path: 'poItemGlobalJsonModel>Itemno'
								}"
								text=""
							/>
							<Text
								id="id_gen_Materialno"
								text="{
									path: 'poItemGlobalJsonModel>Materialno'
								}"
							/>
							<Text
								id="id_gen_shorttext"
								text="{
									path: 'poItemGlobalJsonModel>ShortText'
								}"
							/>
							<Text
								id="id_gen_sloc"
								text="{
									path: 'poItemGlobalJsonModel>Storagebin'
								}"
							/>
							<Text
								id="id_gen_vendor"
								text="{
									path: 'poItemGlobalJsonModel>Vendormaterialno'
								}"
							/>
							<Text
								id="id_gen_price"
								text="{
									path: 'poItemGlobalJsonModel>Price'
								}"
							/>
							<Text
								id="id_textField_PoQuantity"
								text="{
									path: 'poItemGlobalJsonModel>PoQuantity'
								}"
							/>
							<Text
								id="_IDGenText16"
								text="{
									path: 'poItemGlobalJsonModel>Receivedquantity'
								}"
							/>
							<Text
								id="_IDGenText17"
								text="{
									path: 'poItemGlobalJsonModel>Uom'
								}"
							/>
							<Input
								id="id_PostingQuantityInputField"
								visible="{poItemGlobalJsonModel>PostingQuantityFlag}"
								value="{poItemGlobalJsonModel>Postingquantity}"
								liveChange="postingQuantityCheckInDetail"
								type="Number"
								width="5rem"
								enabled="{poItemGlobalJsonModel>isInputFieldEnabled}"
								class="input_css"
							/>
							<Input
								id="id_batch_input_field"
								liveChange="batchCheckInDetail"
								visible="{poItemGlobalJsonModel>BatchShowFlag}"
								enabled="{poItemGlobalJsonModel>isInputFieldEnabled}"
								value="{poItemGlobalJsonModel>Batchno}"
								valueStateText=""
								width="5rem"
								class="input_css"
							/>
							<Button
								id="id_for_itemType_Action_Button_in_DetailPage"
								type="{poItemGlobalJsonModel>ButtonType}"
								text="{
									path: 'poItemGlobalJsonModel>ItemType'
								}"
								width="5rem"
								enabled="{
									path: 'poItemGlobalJsonModel>isButtonEnabled'
								}"
								press="onActionButtonPressInItemsTable"
							>
							</Button>
						</cells>
					</ColumnListItem>
				</items>
			</Table>
		</semantic:content>
		<semantic:titleCustomIconActions>
			<OverflowToolbarButton
				id="printLabelBtn"
				icon="sap-icon://print"
				text="print"
				press="onPrintButtonPress"
			/>
		</semantic:titleCustomIconActions>
		<!--Semantic ShareMenu Buttons-->
		<semantic:closeAction>
			<semantic:CloseAction
				id="closeColumn"
				press="onResetButtonPress"
			/>
			<!-- press="onCloseDetailPress" -->
		</semantic:closeAction>
		<semantic:fullScreenAction>
			<semantic:FullScreenAction
				id="enterFullScreen"
				visible="{= !${device>/system/phone} &amp;&amp; !${appView>/actionButtonsInfo/midColumn/fullScreen}}"
				press="toggleFullScreen"
			/>
		</semantic:fullScreenAction>
		<semantic:exitFullScreenAction>
			<semantic:ExitFullScreenAction
				id="exitFullScreen"
				visible="{= !${device>/system/phone} &amp;&amp; ${appView>/actionButtonsInfo/midColumn/fullScreen}}"
				press="toggleFullScreen"
			/>
		</semantic:exitFullScreenAction>
		<semantic:positiveAction>
			<semantic:PositiveAction
				id="id_savepo"
				text="{i18n>Post}"
				press="onPOSTPOButtonPress"
			/>
		</semantic:positiveAction>
		<semantic:negativeAction>
			<semantic:NegativeAction
				id="id_reset"
				text="{i18n>Cancel}"
				press="onResetButtonPress"
			/>
		</semantic:negativeAction>
	</semantic:SemanticPage>
</mvc:View>